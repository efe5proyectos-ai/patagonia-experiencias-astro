---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { obtenerExperiencias } from '../../lib/contenido.js';
const exps = await obtenerExperiencias();
const urgColores = { rose:'bg-rose-600/95 border-rose-500', amber:'bg-amber-500/95 border-amber-400', emerald:'bg-emerald-600/95 border-emerald-500', sky:'bg-sky-600/95 border-sky-500', fuchsia:'bg-fuchsia-600/95 border-fuchsia-500', slate:'bg-slate-700/95 border-slate-600' };
---
<BaseLayout titulo="Experiencias en la Patagonia" descripcion="Excursiones y experiencias verificadas con prestadores locales: avistaje de ballenas, La Hoya, Los Alerces, Huella Galesa y todo el Chubut.">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-brand-fuchsia text-xs font-black uppercase tracking-[0.3em] mb-3"><i class="fa-solid fa-circle-check mr-2"></i>Catálogo verificado</p>
    <h1 class="font-sans font-extrabold text-3xl sm:text-5xl leading-tight mb-10 text-brand-oxford">Experiencias</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {exps.map((e) => {
        const pct = e.precios.ahorro > 0 && e.precios.precioLista > 0 ? Math.round((e.precios.ahorro / e.precios.precioLista) * 100) : 0;
        return (
        <a href={`/experiencias/${e.slug}/`} class="group bg-white rounded-2xl overflow-hidden flex flex-col shadow-md hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
          <div class="relative h-52 overflow-hidden">
            {e.imagen && <img src={e.imagen} alt={`${e.titulo} — ${e.destino}`} loading="lazy" width="600" height="400" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />}
            {e.etiqueta && (
              <div class="absolute top-4 left-4 max-w-[calc(100%-2rem)] bg-brand-fuchsia px-3 py-1.5 rounded-md text-[10px] font-bold uppercase tracking-widest text-white shadow-md z-10 border border-brand-fuchsiaDark flex items-center gap-1">
                <span class="text-white/80 font-black text-sm leading-none">#</span> <span class="truncate">{e.etiqueta}</span>
              </div>
            )}
            {pct > 0 && (
              <div class="absolute bottom-6 left-4 bg-emerald-500 text-white text-base font-black px-3 py-1.5 rounded-lg shadow-xl z-10 uppercase tracking-wider flex items-center gap-1.5 border-2 border-white">
                <i class="fa-solid fa-tag text-xs"></i>-{pct}%
              </div>
            )}
            {e.likes > 0 && (
              <div class="absolute bottom-6 right-4 backdrop-blur-md px-2.5 py-1.5 rounded-lg flex items-center justify-center border z-20 shadow-sm gap-1.5 bg-white/20 border-white/30 text-white">
                <i class="fa-regular fa-heart text-sm"></i><span class="text-xs font-bold">{e.likes}</span>
              </div>
            )}
            {e.urgencia && e.urgencia.texto && (
              <div class={`absolute bottom-0 left-0 right-0 backdrop-blur-md py-1.5 px-3 text-white text-[10px] font-black tracking-widest uppercase text-center flex justify-center items-center gap-2 border-t shadow-lg ${urgColores[e.urgencia.color] || urgColores.rose}`}>
                {e.urgencia.icono && <i class={`fa-solid ${e.urgencia.icono}`}></i>}{e.urgencia.texto}
              </div>
            )}
          </div>
          <div class="p-5 flex flex-col flex-grow">
            <div class="mb-2">
              {e.proveedor && <p class="text-[10px] text-brand-fuchsia font-bold uppercase tracking-widest mb-1.5 flex items-center gap-1"><i class="fa-solid fa-store opacity-70"></i> {e.proveedor}</p>}
              <div class="flex justify-between items-start gap-3">
                <h2 class="font-sans font-bold text-brand-dark text-[15px] leading-tight group-hover:text-brand-fuchsia transition-colors">{e.titulo}</h2>
                <div class="flex items-center gap-1 text-[11px] font-bold flex-shrink-0 bg-yellow-50 text-yellow-700 px-1.5 py-0.5 rounded border border-yellow-100">
                  <i class="fa-solid fa-star text-[10px] text-yellow-500"></i> {Number(e.rating).toFixed(1)}
                </div>
              </div>
            </div>
            <div class="space-y-1.5 mb-4 mt-2">
              <p class="text-slate-500 text-[11px] font-semibold flex items-center gap-1.5"><i class="fa-solid fa-location-dot w-4 text-center text-brand-fuchsia opacity-80 text-sm"></i> {e.destino}</p>
              <p class="text-slate-500 text-[11px] font-semibold flex items-center gap-1.5"><i class="fa-regular fa-clock w-4 text-center opacity-60 text-sm text-brand-fuchsia"></i> {e.duracion || 'Consultar'}</p>
            </div>
            <div class="mt-auto border-t border-slate-100 pt-4 flex items-center justify-between">
              <div class="flex flex-col w-full gap-0.5">
                {e.esGastroReferencia ? (
                  <span class="flex items-center gap-1.5 mt-1"><i class="fa-solid fa-utensils text-amber-500 text-sm"></i><span class="font-sans font-bold text-sm text-amber-600 uppercase tracking-wide">Lugar recomendado</span></span>
                ) : e.precios.ahorro > 0 ? (
                  <>
                    <span class="font-sans font-black text-lg text-slate-400 line-through leading-none">${e.precios.precioLista.toLocaleString('es-AR')}</span>
                    <span class="font-sans font-black text-2xl text-brand-fuchsia leading-none">${e.precios.precioFinal.toLocaleString('es-AR')}</span>
                    <span class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest mt-0.5 flex items-center gap-1"><i class="fa-solid fa-piggy-bank text-[9px]"></i>Ahorrás ${e.precios.ahorro.toLocaleString('es-AR')}</span>
                  </>
                ) : e.precios.precioFinal > 0 ? (
                  <span class="font-sans font-black text-2xl text-brand-dark leading-none mt-1">${e.precios.precioFinal.toLocaleString('es-AR')}</span>
                ) : null}
              </div>
              <span class="w-9 h-9 rounded-full bg-slate-100 text-slate-500 flex items-center justify-center group-hover:bg-brand-fuchsia group-hover:text-white transition-colors shadow-sm flex-shrink-0"><i class="fa-solid fa-arrow-right text-sm"></i></span>
            </div>
            {!e.esGastroReferencia && e.precios.sena > 0 && (
              <div class="mt-3 -mx-5 bg-brand-fuchsia text-white px-4 py-2.5 flex items-center justify-between gap-3">
                <div class="flex items-center gap-2"><i class="fa-solid fa-bolt text-base flex-shrink-0"></i><span class="text-[11px] font-bold uppercase tracking-wider leading-tight text-left">Reservalo<br/>HOY con</span></div>
                <div class="flex flex-col items-end leading-none"><span class="font-sans font-black text-2xl">${e.precios.sena.toLocaleString('es-AR')}</span><span class="text-[9px] font-medium uppercase tracking-widest opacity-80 mt-0.5">Seña Preventa</span></div>
              </div>
            )}
            {!e.esGastroReferencia && e.puntos > 0 && (
              <div class={`${e.precios.sena > 0 ? '' : 'mt-3 '}-mx-5 -mb-5 bg-slate-600 text-white px-4 py-2 flex items-center justify-center gap-2 text-[11px] font-bold uppercase tracking-wider`}>
                <i class="fa-solid fa-coins"></i>Sumás +{e.puntos.toLocaleString('es-AR')} pts
              </div>
            )}
          </div>
        </a>
      )})}
    </div>
  </main>
</BaseLayout>
