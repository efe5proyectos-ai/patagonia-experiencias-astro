---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { obtenerGuias } from '../../lib/contenido.js';
const guias = await obtenerGuias();
const categorias = [...new Set(guias.map((g) => g.destino).filter(Boolean))].sort();
---
<BaseLayout titulo="Guías de viaje de la Patagonia" descripcion="Guías completas para planificar tu viaje por Chubut y la Patagonia: destinos, secretos locales, temporadas y experiencias verificadas." temaOscuro={true}>
  <main>
    <section class="bg-[#0d1117] pt-14 pb-8 px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <p class="text-brand-fuchsia text-xs font-black uppercase tracking-[0.3em] mb-3"><i class="fa-solid fa-newspaper mr-2"></i>Patagonia Magazine</p>
        <h1 class="font-sans font-extrabold text-3xl sm:text-5xl leading-tight mb-4">Guías de viaje</h1>
        <p class="text-white/50 max-w-2xl text-sm sm:text-base leading-relaxed">Destinos, eventos y secretos de la región más austral del mundo. Contenido editorial que inspira tu próximo viaje.</p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
        {guias.map((g) => (
          <a href={`/guias/${g.slug}/`} class="group bg-white/5 border border-white/10 rounded-2xl overflow-hidden flex flex-col hover:border-brand-fuchsia/50 hover:-translate-y-1 transition-all duration-300">
            {g.imagen && (
              <div class="relative h-52 overflow-hidden">
                <img src={g.imagen} alt={`${g.titulo} — Patagonia`} loading="lazy" width="600" height="400" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                {g.destino && <span class="absolute top-4 left-4 bg-brand-fuchsia text-white text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-md shadow-sm flex items-center gap-1.5"><i class="fa-solid fa-star"></i> {g.destino}</span>}
              </div>
            )}
            <div class="p-6 flex flex-col flex-grow">
              <h2 class="font-sans font-bold text-[15px] mb-4 leading-snug group-hover:text-brand-fuchsia transition-colors flex-grow">{g.titulo}</h2>
              <div class="flex justify-between items-center text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-auto border-t border-slate-700/50 pt-4">
                <span><i class="fa-regular fa-compass mr-1 opacity-70"></i> Patagonia</span>
                <span class="group-hover:text-brand-fuchsia transition-colors">Leer Artículo <i class="fa-solid fa-arrow-right ml-0.5"></i></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
