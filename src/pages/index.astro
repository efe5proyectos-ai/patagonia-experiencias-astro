---
// ─────────────────────────────────────────────────────────────
// HOME — Clon estático del derivador de producción (index.html)
// Mismo diseño, pero el contenido vive en el HTML: Google lo lee.
// El carrusel de fondo se genera en el build con configuracion/medios.
// ─────────────────────────────────────────────────────────────
import '../styles/global.css';
import { obtenerMediosHub } from '../lib/contenido.js';
const { items: medios, intervaloMs } = await obtenerMediosHub();
const schema = [
  { '@context': 'https://schema.org', '@type': 'Organization', name: 'Patagonia Experiencias',
    url: 'https://patagoniaexperiencias.com', sameAs: ['https://www.instagram.com/patagoniaexperienciasok'] },
  { '@context': 'https://schema.org', '@type': 'WebSite', name: 'Patagonia Experiencias',
    url: 'https://patagoniaexperiencias.com' },
];
---
<!doctype html>
<html lang="es-AR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Patagonia Experiencias | Conectando la Patagonia</title>
  <meta name="description" content="La red que conecta las mejores experiencias de la Patagonia con quienes buscan vivirlas: tours, alojamientos y gastronomía con prestadores locales verificados de todo el Chubut." />
  <link rel="canonical" href="https://patagoniaexperiencias.com/" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Patagonia Experiencias | Conectando la Patagonia" />
  <meta property="og:description" content="Tours, alojamientos y gastronomía con prestadores locales verificados de la Patagonia." />
  <meta property="og:image" content="https://patagoniaexperiencias.com/og-image.png" />
  <meta property="og:url" content="https://patagoniaexperiencias.com/" />
  <meta property="og:locale" content="es_AR" />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <!-- Meta Pixel Base · Patagonia Experiencias -->
  <script is:inline>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window,document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1501384968138883');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=1501384968138883&ev=PageView&noscript=1"/></noscript>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <style>
    html, body { margin: 0; padding: 0; height: 100%; background-color: #FDFDFD; color: #2c3e50; overflow: hidden; }
    .card-link { transition: all 0.3s ease; }
    .card-link:hover { transform: translateY(-2px); box-shadow: 0 15px 30px -5px rgba(233, 30, 99, 0.2); }
    .card-link:hover i.icon-action { transform: translateX(5px); }
    @keyframes float { 0% { transform: translateY(0px); } 50% { transform: translateY(-10px); } 100% { transform: translateY(0px); } }
    .animate-float { animation: float 6s ease-in-out infinite; }
    .left-panel::-webkit-scrollbar { width: 6px; }
    .left-panel::-webkit-scrollbar-track { background: transparent; }
    .left-panel::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .hub-slide { transition: opacity 1s ease-in-out; }
    @media (max-width: 1024px) { html, body { overflow: auto; height: auto; } }
  </style>
</head>
<body class="antialiased selection:bg-brand-fuchsia selection:text-white font-body">
  <div class="flex flex-col-reverse lg:flex-row h-screen w-full bg-brand-snow">

    <!-- PANEL IZQUIERDO -->
    <div class="w-full lg:w-1/2 h-full left-panel overflow-y-auto bg-white flex flex-col relative z-10 shadow-2xl lg:shadow-[10px_0_30px_rgba(0,0,0,0.05)]">
      <div class="h-2 w-full bg-brand-fuchsia absolute top-0 left-0"></div>
      <div class="flex-1 w-full flex flex-col justify-center pt-8">
        <div class="px-8 md:px-12 lg:px-16 xl:px-20 pb-8 max-w-2xl mx-auto w-full">
          <div class="mb-10 text-center lg:text-left mt-8 lg:mt-0">
            <h2 class="font-sans font-bold text-2xl md:text-3xl text-brand-oxford uppercase tracking-tight mb-2">Acá empieza tu viaje</h2>
            <p class="text-gray-500 font-medium">Elegí tu camino. La Patagonia te espera.</p>
          </div>
          <div class="mb-4">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-500"><i class="fa-solid fa-plane"></i></div>
              <h3 class="font-sans font-bold text-sm uppercase tracking-widest text-gray-400">Para Turistas &amp; Viajeros</h3>
            </div>
            <div class="space-y-4">
              <a href="/patagonia-experiencias.html" class="w-full card-link block bg-brand-fuchsia rounded-2xl p-4 md:p-5 flex items-center justify-between group shadow-lg hover:bg-brand-fuchsiaDark transition-all duration-300 transform scale-[1.02] text-left">
                <div class="flex items-center gap-3 md:gap-4">
                  <div class="w-10 h-10 md:w-12 md:h-12 bg-white/20 rounded-xl flex items-center justify-center text-white text-base md:text-xl transition-all duration-300"><i class="fa-solid fa-map-marked-alt"></i></div>
                  <div>
                    <h4 class="font-sans font-bold text-white text-base md:text-lg leading-none mb-1">Descubrí tu próximo destino ahora</h4>
                    <p class="text-xs text-white/90 font-medium">Mirá tours, alojamientos y experiencias. Entrá libre.</p>
                  </div>
                </div>
                <i class="fa-solid fa-arrow-right text-white text-lg icon-action transition-all"></i>
              </a>
              <a href="/guias/" class="w-full card-link block bg-white border border-gray-100 rounded-2xl p-4 md:p-5 flex items-center justify-between group shadow-sm hover:bg-brand-fuchsia transition-all duration-300 text-left">
                <div class="flex items-center gap-3 md:gap-4">
                  <div class="w-10 h-10 md:w-12 md:h-12 bg-gray-100 group-hover:bg-white/20 rounded-xl flex items-center justify-center text-gray-500 group-hover:text-white text-base md:text-xl transition-all duration-300"><i class="fa-solid fa-newspaper"></i></div>
                  <div>
                    <h4 class="font-sans font-bold text-brand-oxford group-hover:text-white text-base md:text-lg leading-none mb-1">Leé nuestras guías de viaje</h4>
                    <p class="text-xs text-gray-500 group-hover:text-white/90 font-medium">Destinos, secretos locales y temporadas.</p>
                  </div>
                </div>
                <i class="fa-solid fa-arrow-right text-gray-300 group-hover:text-white text-lg icon-action transition-all"></i>
              </a>
            </div>
          </div>
        </div>
        <div class="w-full bg-white border-t border-gray-100 py-4">
          <div class="px-8 md:px-12 lg:px-16 xl:px-20 max-w-2xl mx-auto w-full">
            <div class="flex justify-around items-center text-center gap-3">
              <div class="flex-1">
                <p class="font-sans font-extrabold text-brand-oxford text-xl md:text-2xl leading-none">+200</p>
                <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mt-1">Prestadores</p>
              </div>
              <div class="w-px h-10 bg-gray-200"></div>
              <div class="flex-1">
                <p class="font-sans font-extrabold text-brand-oxford text-xl md:text-2xl leading-none">+5.000</p>
                <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mt-1">Usuarios</p>
              </div>
              <div class="w-px h-10 bg-gray-200"></div>
              <div class="flex-1">
                <p class="font-sans font-bold text-brand-oxford text-[11px] md:text-xs uppercase tracking-wider leading-tight">Experiencias</p>
                <p class="font-sans font-bold text-brand-oxford text-[11px] md:text-xs uppercase tracking-wider leading-tight mt-1">Alojamientos</p>
                <p class="font-sans font-bold text-brand-oxford text-[11px] md:text-xs uppercase tracking-wider leading-tight mt-1">Gastronomía</p>
              </div>
            </div>
          </div>
        </div>
        <div class="w-full bg-[#f3f4f6] border-y border-gray-200 mt-auto">
          <div class="px-8 md:px-12 lg:px-16 xl:px-20 py-10 max-w-2xl mx-auto w-full">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-500"><i class="fa-solid fa-briefcase"></i></div>
              <h3 class="font-sans font-bold text-sm uppercase tracking-widest text-gray-500">Para Prestadores Turísticos</h3>
            </div>
            <div class="space-y-4">
              <a href="/prestadores.html" class="card-link block bg-white rounded-2xl p-4 md:p-5 flex items-center justify-between group border border-gray-100 shadow-sm hover:bg-brand-fuchsia transition-all duration-300">
                <div class="flex items-center gap-3 md:gap-4">
                  <div class="w-10 h-10 md:w-12 md:h-12 bg-gray-100 group-hover:bg-white/20 rounded-xl flex items-center justify-center text-gray-500 group-hover:text-white text-base md:text-xl transition-all duration-300"><i class="fa-solid fa-store"></i></div>
                  <div>
                    <h4 class="font-sans font-bold text-brand-oxford group-hover:text-white text-base md:text-lg leading-none mb-1">Publicá tus Servicios</h4>
                    <p class="text-xs text-gray-500 group-hover:text-white/90 font-medium">Alojamiento, gastronomía, excursiones y más.</p>
                  </div>
                </div>
                <i class="fa-solid fa-arrow-right text-gray-300 group-hover:text-white text-lg icon-action transition-all"></i>
              </a>
              <div class="text-center pt-1">
                <a href="https://patagoniaexperiencias.com/dashboard-prestadores.html" class="text-xs text-gray-500 hover:text-brand-fuchsia font-medium transition-colors inline-flex items-center gap-1.5">
                  <i class="fa-solid fa-right-to-bracket text-[10px]"></i>¿Ya sos parte? Accedé a tu panel
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-auto border-t border-brand-border pt-8 pb-6 px-6 bg-white w-full">
        <div class="max-w-2xl mx-auto flex flex-col gap-6 w-full">
          <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
            <img src="/logo-patagonia-puntos.png" alt="Patagonia Puntos" class="h-8 object-contain" loading="lazy" />
            <img src="/logo-patagonia-magazine.png" alt="Patagonia Magazine" class="h-8 object-contain" loading="lazy" />
            <img src="/logo-octopus.png" alt="Octopus" class="h-8 object-contain" loading="lazy" />
          </div>
          <div class="flex justify-center items-center gap-4 py-2">
            <a href="https://www.instagram.com/patagoniapuntos/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 rounded-full bg-gray-100 hover:bg-brand-fuchsia text-gray-500 hover:text-white flex items-center justify-center transition-all duration-300"><i class="fa-brands fa-instagram text-base"></i></a>
            <a href="https://www.facebook.com/patagoniapuntos/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-9 h-9 rounded-full bg-gray-100 hover:bg-brand-fuchsia text-gray-500 hover:text-white flex items-center justify-center transition-all duration-300"><i class="fa-brands fa-facebook-f text-base"></i></a>
            <a href="https://wa.me/5492804356028?text=Hola%2C%20los%20contacto%20desde%20el%20sitio%20web%20de%20Patagonia%20Experiencias.%20Necesito%20informaci%C3%B3n." target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="w-9 h-9 rounded-full bg-gray-100 hover:bg-brand-fuchsia text-gray-500 hover:text-white flex items-center justify-center transition-all duration-300"><i class="fa-brands fa-whatsapp text-base"></i></a>
          </div>
          <div class="flex justify-center items-center border-t border-gray-100 pt-6">
            <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest flex items-center gap-1.5 text-center">
              <span class="text-brand-fuchsia"><i class="fa-solid fa-bolt"></i></span>
              Powered by OCTOPUS &amp; efe5 proyectos
              <a href="https://patagoniaexperiencias.com/admin-master.html" class="ml-2 hover:text-brand-fuchsia transition-colors" title="Acceso Maestro" aria-label="Acceso maestro"><i class="fa-solid fa-lock"></i></a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- PANEL DERECHO: carrusel de medios (generado en el build desde Firestore) -->
    <div class="relative w-full h-[60vh] lg:h-full lg:w-1/2 overflow-hidden bg-gradient-to-br from-brand-oxford via-brand-fuchsiaDark to-brand-fuchsia" id="hub-media">
      {medios.map((m, i) => (
        <div class="hub-slide absolute inset-0" style={`opacity:${i === 0 ? 1 : 0}`}>
          {m.tipo === 'video' ? (
            <video src={m.url} class="w-full h-full object-cover" autoplay muted loop playsinline></video>
          ) : m.tipo === 'youtube' ? (
            <iframe src={`https://www.youtube.com/embed/${m.videoId}?autoplay=1&mute=1&loop=1&playlist=${m.videoId}&controls=0&showinfo=0&modestbranding=1&playsinline=1&rel=0`} class="w-full h-full pointer-events-none" style="border:0;transform:scale(1.5)" allow="autoplay; encrypted-media" title="Video de fondo"></iframe>
          ) : (
            <img src={m.url} class="w-full h-full object-cover" alt="Paisajes de la Patagonia: destinos y experiencias" loading={i === 0 ? 'eager' : 'lazy'} />
          )}
        </div>
      ))}
      <div class="absolute inset-0 bg-gradient-to-t from-brand-oxford/90 via-brand-oxford/20 to-transparent"></div>
      <div class="absolute bottom-10 left-8 right-8 lg:right-12 lg:bottom-16 lg:text-right">
        <div class="w-14 h-14 md:w-16 md:h-16 bg-brand-fuchsia rounded-2xl flex items-center justify-center text-white shadow-2xl mb-5 md:mb-6 lg:ml-auto"><i class="fa-solid fa-mountain-sun text-2xl md:text-3xl"></i></div>
        <h1 class="font-sans font-black text-3xl md:text-4xl lg:text-6xl text-white uppercase italic tracking-tighter leading-none mb-4 drop-shadow-lg animate-float">Descubrí <br /><span class="text-brand-fuchsia">Patagonia</span></h1>
        <p class="text-white/80 font-medium text-lg lg:ml-auto max-w-md hidden md:block">La red que conecta las mejores experiencias de la Patagonia con quienes buscan vivirlas intensamente.</p>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ intervaloMs }}>
    // Rotación del carrusel (mejora progresiva: sin JS igual se ve la primera foto)
    const slides = document.querySelectorAll('#hub-media .hub-slide');
    if (slides.length > 1) {
      let actual = 0;
      setInterval(() => {
        slides[actual].style.opacity = 0;
        actual = (actual + 1) % slides.length;
        slides[actual].style.opacity = 1;
      }, intervaloMs);
    }
  </script>
</body>
</html>
