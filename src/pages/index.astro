---
import BaseLayout from '../layouts/BaseLayout.astro';
import { obtenerGuias, obtenerExperiencias } from '../lib/contenido.js';
const guias = (await obtenerGuias()).slice(0, 6);
const exps = (await obtenerExperiencias()).slice(0, 6);
---
<BaseLayout titulo="Experiencias verificadas en la Patagonia" descripcion="Reservá excursiones y experiencias con prestadores locales verificados en Chubut y la Patagonia. Avistaje de ballenas, La Hoya, Los Alerces, Huella Galesa y más.">
  <main>
    <section class="bg-brand-dark text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
        <h1 class="font-sans font-extrabold text-4xl sm:text-6xl leading-tight mb-5">La Patagonia se decide<br /><span class="text-brand-fuchsia">antes de llegar</span></h1>
        <p class="text-white/60 max-w-2xl mx-auto mb-8">Guías, destinos y experiencias verificadas con prestadores locales de todo el Chubut.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/experiencias/" class="bg-brand-fuchsia hover:bg-brand-fuchsiaDark text-white font-bold text-sm uppercase tracking-widest px-8 py-4 rounded-full shadow-lg shadow-brand-fuchsia/30 transition-all">Ver experiencias</a>
          <a href="/guias/" class="bg-white/10 hover:bg-white/20 text-white font-bold text-sm uppercase tracking-widest px-8 py-4 rounded-full transition-all">Leer guías</a>
        </div>
      </div>
    </section>
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="font-sans font-extrabold text-2xl text-brand-oxford mb-8">Experiencias destacadas</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
        {exps.map((e) => (
          <a href={`/experiencias/${e.slug}/`} class="group bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all">
            {e.imagen && <img src={e.imagen} alt={e.titulo} loading="lazy" width="600" height="400" class="h-44 w-full object-cover group-hover:scale-105 transition-transform duration-500" />}
            <div class="p-5"><h3 class="font-sans font-bold text-sm leading-snug group-hover:text-brand-fuchsia transition-colors">{e.titulo}</h3>
            {e.precio && <p class="font-sans font-extrabold text-brand-fuchsia mt-2">${e.precio.toLocaleString('es-AR')}</p>}</div>
          </a>
        ))}
      </div>
    </section>
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <h2 class="font-sans font-extrabold text-2xl text-brand-oxford mb-8">Últimas guías</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
        {guias.map((g) => (
          <a href={`/guias/${g.slug}/`} class="group bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all">
            {g.imagen && <img src={g.imagen} alt={g.titulo} loading="lazy" width="600" height="400" class="h-44 w-full object-cover group-hover:scale-105 transition-transform duration-500" />}
            <div class="p-5"><h3 class="font-sans font-bold text-sm leading-snug group-hover:text-brand-fuchsia transition-colors">{g.titulo}</h3></div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
